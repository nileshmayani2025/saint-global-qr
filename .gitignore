# public/build is committed on purpose: the live server (shared cPanel hosting)
# has no Node/npm to run `npm run build`, so the compiled assets ship in the repo.
# Rebuild with `npm run build` and commit the result whenever CSS/JS changes.
/public/hot
/public/storage
/storage/*.key
/storage/pail
# Firebase service-account credentials — private key, never commit.
/storage/app/firebase

# Runtime caches — regenerated on every request, must never be committed.
/storage/framework/cache/data
/storage/framework/sessions
/storage/framework/testing
/storage/framework/views
/storage/logs
/vendor
Homestead.json
Homestead.yaml
Thumbs.db
